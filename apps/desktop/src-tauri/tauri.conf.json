{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LAWRENCE",
  "version": "0.1.0",
  "identifier": "local.lawrence.desktop",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LAWRENCE",
        "width": 920,
        "height": 340,
        "minWidth": 720,
        "minHeight": 260,
        "maxWidth": 1200,
        "maxHeight": 560,
        "decorations": false,
        "resizable": true,
        "maximizable": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
