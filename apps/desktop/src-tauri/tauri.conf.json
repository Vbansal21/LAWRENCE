{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LAWRENCE",
  "version": "0.1.0",
  "identifier": "local.lawrence.desktop",
  "build": {
    "beforeDevCommand": "python3 -m http.server 1420 --directory web",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LAWRENCE",
        "width": 900,
        "height": 340,
        "minWidth": 760,
        "minHeight": 300,
        "decorations": false,
        "resizable": false,
        "transparent": true,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
