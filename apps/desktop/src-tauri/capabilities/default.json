{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for the LAWRENCE frameless launcher: drag-to-move, custom resize, show/hide/focus, event bus, and global-shortcut.",
  "windows": ["main", "panel-settings", "panel-advanced", "panel-tasks", "panel-reminders", "panel-history"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:app:allow-version",
    "core:window:allow-start-dragging",
    "core:window:allow-start-resize-dragging",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-inner-size",
    "core:window:allow-outer-size",
    "core:window:allow-inner-position",
    "core:window:allow-scale-factor",
    "core:window:allow-minimize",
    "core:window:allow-unminimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-is-minimized",
    "core:window:allow-is-focused",
    "core:window:allow-is-visible",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-set-focus",
    "core:window:allow-center",
    "core:window:allow-set-always-on-top",
    "core:window:allow-set-resizable",
    "core:window:allow-set-decorations",
    "core:window:allow-set-shadow",
    "core:window:allow-set-visible-on-all-workspaces",
    "core:window:allow-current-monitor",
    "core:window:allow-primary-monitor",
    "core:window:allow-available-monitors",
    "core:webview:allow-internal-toggle-devtools",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-unregister-all",
    "global-shortcut:allow-is-registered"
  ]
}
